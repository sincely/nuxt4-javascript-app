{
  "name": "nuxt4-javascript-app",
  "private": true,
  "version": "2.0.0",
  "scripts": {
    "dev": "nuxt dev --dotenv .env.development --host",
    "test": "nuxt dev --dotenv .env.test",
    "prod": "nuxt dev --dotenv .env.production",
    "build": "nuxt build",
    "build:dev": "nuxt build --dotenv .env.development",
    "build:test": "nuxt build --dotenv .env.test",
    "build:prod": "nuxt build --dotenv .env.production",
    "start": "node .output/server/index.mjs",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint-staged": "lint-staged",
    "lint": "eslint .",
    "prepare": "husky",
    "prettier:fix": "prettier --write \"./**/*.{js,vue,scss,css,json}\"",
    "stylelint:fix": "stylelint \"{app/components,app/layouts,app/pages,app/assets,app/styles}/**/*.{vue,css,scss}\" --fix",
    "release": "release-it",
    "release:dry-run": "release-it --dry-run",
    "release:changelog": "release-it --only-changelog",
    "release:github": "release-it --ci --github.release",
    "release:patch": "release-it patch",
    "release:minor": "release-it minor",
    "release:major": "release-it major",
    "release:alpha": "release-it --preRelease=alpha",
    "release:beta": "release-it --preRelease=beta"
  },
  "dependencies": {
    "@element-plus/icons-vue": "2.3.2",
    "@element-plus/nuxt": "1.1.5",
    "@iconify-json/carbon": "1.2.22",
    "@iconify-json/twemoji": "1.2.5",
    "@nuxt/image": "2.0.0",
    "@nuxt/icon": "2.2.2",
    "@nuxtjs/color-mode": "4.0.0",
    "@nuxtjs/seo": "5.1.3",
    "@nuxtjs/supabase": "2.0.9",
    "@pinia/nuxt": "0.11.3",
    "@supabase/supabase-js": "2.106.2",
    "@unocss/nuxt": "66.7.0",
    "@unocss/preset-rem-to-px": "66.7.0",
    "@vueuse/core": "14.3.0",
    "@vueuse/nuxt": "14.3.0",
    "animejs": "3.2.2",
    "element-plus": "2.14.1",
    "mitt": "3.0.1",
    "node-fetch-native": "1.6.7",
    "nuxt": "4.4.6",
    "nuxt-gtag": "4.1.0",
    "nuxt-umami": "3.2.1",
    "pinia": "3.0.4",
    "pinia-plugin-persistedstate": "4.7.1",
    "swiper": "11.1.14",
    "vue": "3.5.35",
    "vue-router": "5.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@nuxt/eslint-config": "1.15.2",
    "@release-it/conventional-changelog": "11.0.1",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "eslint": "9.28.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "prettier": "3.8.3",
    "release-it": "20.2.0",
    "sass": "1.100.0",
    "stylelint": "17.12.0",
    "stylelint-config-html": "1.1.0",
    "stylelint-config-recess-order": "7.7.0",
    "stylelint-config-recommended-scss": "17.0.1",
    "stylelint-config-standard": "40.0.0",
    "stylelint-config-standard-scss": "17.0.0",
    "stylelint-scss": "7.1.1",
    "stylelint-order": "8.1.1"
  }
}